# PostgreSQL
POSTGRES_USER=maktaba
POSTGRES_PASSWORD=maktaba
POSTGRES_DB=maktaba
POSTGRES_PORT=5432
DATABASE_URL=postgres://maktaba:maktaba@localhost:5432/maktaba?sslmode=disable

# Go service
APP_PORT=8080
PORT=8080
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Auth
AUTH_ISSUER=bayt-alhikmah
AUTH_AUDIENCE=bayt-alhikmah-api
AUTH_ACCESS_TOKEN_LIFETIME=15m
AUTH_REFRESH_TOKEN_LIFETIME=720h
AUTH_COOKIE_SECURE=false

# Base64-encoded Ed25519 32-byte seed or 64-byte private key.
# Generate one with: openssl rand -base64 32
AUTH_ED25519_PRIVATE_KEY=

# Frontend
VITE_MAKTABA_API_URL=http://localhost:8080
