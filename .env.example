# =============================================================================
# Bayt al Hikmah - Environment Configuration
# =============================================================================

# =============================================================================
# PostgreSQL Configuration (Single instance, multiple databases)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_change_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=25
POSTGRES_DB=postgres

# =============================================================================
# Maktaba Service Database
# =============================================================================
MAKTABA_DB_USER=maktaba
MAKTABA_DB_PASSWORD=maktaba_change_in_production
MAKTABA_DB_NAME=maktaba
MAKTABA_DB_URL=postgres://maktaba:maktaba_change_in_production@postgres:5432/maktaba?sslmode=disable


# =============================================================================
# Ory Console Settings
# =============================================================================


# =============================================================================
# Meilisearch Configuration
# =============================================================================
MEILISEARCH_HOST=http://meilisearch
MEILISEARCH_PORT=7700
MEILISEARCH_MASTER_KEY=meilisearch_master_key_change_in_production

# =============================================================================
# pgAdmin Configuration
# =============================================================================
PGADMIN_PORT=5050
PGADMIN_DEFAULT_SERVER=postgres
PGADMIN_SERVER_PORT=5432
PGADMIN_SERVER_HOST=postgres
PGADMIN_SERVER_USER=postgres
PGADMIN_SERVER_PASSWORD=${POSTGRES_PASSWORD}
PGADMIN_DEFAULT_DATABASE=maktaba
PGADMIN_CONFIG_SERVER_MODE=single


# =============================================================================
# Service Ports
# =============================================================================
MAKTABA_PORT=8080
BAHITH_PORT=8003
MURSHID_PORT=8004
FRONTEND_PORT=3000

# =============================================================================
# Service URLs (Internal Docker Network)
# =============================================================================
MAKTABA_URL=http://maktaba:8080
BAHITH_URL=http://bahith:8003
MURSHID_URL=http://murshid:8004

# =============================================================================
# JWT Configuration (fallback for development)
# =============================================================================
JWT_SECRET=jwt_secret_change_in_production_min_32_chars
JWT_ISSUER=bayt-alhikmah
JWT_AUDIENCE=bayt-alhikmah-users
JWT_EXPIRY_MINUTES=60


# =============================================================================
# Environment Settings
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=debug

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Session-Token

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_ORY_SDK_URL=https://sleepy-swartz-8u1sjz0in0.projects.oryapis.com
VITE_KRATOS_PUBLIC_URL=http://localhost:4433
VITE_MAKTABA_API_URL=http://localhost:8080

# =============================================================================
# Migration Settings
# =============================================================================
MIGRATIONS_PATH=./migrations
MIGRATIONS_DATABASE_URL=${MAKTABA_DB_URL}
