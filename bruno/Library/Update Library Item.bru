meta {
  name: Update Library Item
  type: http
  seq: 4
}

put {
  url: {{base_url}}/api/library/items/{{library_item_id}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "in_progress",
    "progress_value": 25,
    "progress_unit": "percent",
    "visibility": "public"
  }
}
