meta {
  name: Update Review
  type: http
  seq: 6
}

put {
  url: {{base_url}}/api/reviews/{{review_id}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "rating": 4,
    "content": "Still useful, with a few reservations.",
    "is_public": true
  }
}
