meta {
  name: Create Book
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/sources/books
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "The House of Wisdom",
    "subtitle": "How Arabic Science Saved Ancient Knowledge and Gave Us the Renaissance",
    "description": "A book about the transmission of knowledge through the Islamic Golden Age.",
    "isbn_13": "9780143120568",
    "publisher": "Penguin",
    "page_count": 336,
    "language": "en",
    "tags": ["history", "science", "islamic-golden-age"],
    "contributors": [
      {
        "name": "Jim Al-Khalili",
        "role": "author"
      }
    ]
