meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{base_url}}/api/profile
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "display_name": "Bayt Reader",
    "bio": "Tracking books, notes, reviews, and collections.",
    "public_profile": true
  }
}
